---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import ProjectGallery, { type Project } from '../components/ProjectGallery.tsx';
import profilePhoto from '../assets/Photo gw.jpg';

const CV_PATH = '/Keegan_Gerrard_Jahja_CV.pdf';

const stats = [
	{ value: 'HKD 80K', label: 'Merit entry scholarship, PolyU' },
	{ value: '50%', label: 'Pharmacist processing time cut with AI OCR' },
	{ value: '18', label: 'Clients onboarded at Trimegah Securities' },
];

const ticker = [
	'Python', 'SQL', 'Rust', 'C / C++', 'Java', 'JavaScript', 'Nuxt.js',
	'REST APIs', 'AWS', 'Git', 'R', 'Data Analysis', 'Portfolio Analysis',
	'Risk Profiling', 'RAG', 'FastAPI',
];

const now = [
	{ label: 'Studying', value: 'BSc (Hons) CS · PolyU' },
	{ label: 'Leading', value: 'Indonesian Student Association · Person In Charge' },
	{ label: 'Building', value: 'AI Financial Analyst' },
	{ label: 'Speaking', value: 'English · Indonesian · Chinese (basic)' },
	{ label: 'Aiming', value: 'IB & financial services internships' },
];

const journey = [
	{
		period: 'May 2024',
		place: 'Jakarta',
		org: 'Trimegah Securities',
		headline: 'First seat in finance.',
		detail: 'Analyzed portfolios and risk profiles across equities and mutual funds — and onboarded 18 prospective clients.',
	},
	{
		period: 'Jan 2025 — now',
		place: 'Hong Kong',
		org: 'Indonesian Student Association',
		headline: 'Leading, not just coding.',
		detail: 'Person In Charge — planning and running a large-scale student event across multiple teams.',
	},
	{
		period: 'Feb 2025',
		place: 'Hong Kong',
		org: 'HackTheEast',
		headline: '48 hours, one AI companion.',
		detail: 'Took HK AI Companion from concept to a live demo in front of judges.',
	},
	{
		period: 'Jun 2025',
		place: 'Hong Kong',
		org: 'Grandway Education',
		headline: 'IT groundwork.',
		detail: 'Kept systems documented, backed up, and the corporate site running.',
	},
	{
		period: 'Jul 2025',
		place: 'Hong Kong',
		org: 'Nouvelle Biotech',
		headline: 'AI pharmacists can feel.',
		detail: 'OCR + computer-vision pipeline that cut processing time by 50% — shipped on AWS with secure access.',
	},
	{
		period: 'Aug 2025 — now',
		place: 'Hong Kong',
		org: 'Language Service International',
		headline: 'Software that kills busywork.',
		detail: 'A customer enquiry system built end to end, with non-technical stakeholders in the loop.',
	},
];

const projects: Project[] = [
	{
		id: 'ai-financial-analyst',
		title: 'AI Financial Analyst',
		category: 'finance',
		year: '2025',
		size: 'lg',
		summary:
			'Query stocks in natural language — AI-summarized news, interactive charts, and RAG-grounded answers.',
		description:
			'An AI financial assistant built with Python, FastAPI, Streamlit, and Google Gemini 2.0 Flash. Ask about stocks in plain English, get AI-summarized market news, compare tickers with interactive Plotly charts (candlesticks, heatmaps), and receive context-aware answers through RAG over OpenSearch.',
		highlights: [
			'Natural-language stock queries powered by Gemini 2.0 Flash',
			'RAG with OpenSearch for context-aware, grounded responses',
			'Interactive Plotly candlestick and heatmap comparisons',
			'98% faster responses through intelligent caching',
		],
		stack: ['Python', 'FastAPI', 'Streamlit', 'Gemini', 'RAG', 'OpenSearch'],
		repo: 'https://github.com/Keegerrard/AI-Financial-Analyst-Backend',
	},
	{
		id: 'hk-ai-companion',
		title: 'HK AI Companion',
		category: 'ai',
		year: '2025',
		size: 'md',
		summary: 'HackTheEast prototype — AI assistant for tour guidance and study support.',
		description:
			'A hackathon project built under a tight deadline for HackTheEast. HK AI Companion handles tour guidance, study support, and general conversation through intent-based conversation flows, presented live as a working end-to-end prototype.',
		highlights: [
			'Intent-based conversation routing designed from scratch',
			'Working demo delivered within the hackathon window',
			'Presented the prototype live to judges',
		],
		stack: ['Python', 'NLP', 'Prototyping'],
		repo: 'https://github.com/Keegerrard/HTE_CompanionHK',
	},
	{
		id: 'prescription-ocr',
		title: 'Prescription OCR Workflow',
		category: 'ai',
		year: '2025',
		size: 'md',
		summary: 'Enterprise OCR + computer vision that reads prescriptions and counts pills.',
		description:
			'An enterprise workflow built at Nouvelle Biotech using OCR and computer vision to analyze prescriptions and count pills automatically — reducing pharmacist processing time by 50%, deployed on AWS with role-based access controls.',
		highlights: [
			'Cut pharmacist processing time by 50%',
			'Computer-vision pill-counting pipeline',
			'Deployed on AWS with role-based access controls',
		],
		stack: ['OCR', 'Computer Vision', 'Python', 'AWS'],
	},
	{
		id: 'enquiry-web-system',
		title: 'Customer Enquiry Web System',
		category: 'web',
		year: '2025',
		size: 'wide',
		summary: 'Customer-facing system that automates enquiry handling for a language-services firm.',
		description:
			'Built during my part-time web developer role at Language Service International, this customer-facing system automates enquiry handling to reduce manual workload. I implemented the frontend logic and UI components while collaborating closely with non-technical stakeholders.',
		highlights: [
			'Automated enquiry handling, reducing manual workload',
			'Frontend logic and UI components built end to end',
			'Delivered in partnership with non-technical stakeholders',
		],
		stack: ['JavaScript', 'HTML', 'CSS'],
	},
	{
		id: 'cmms-dbms',
		title: 'CMMS Database System',
		category: 'web',
		year: '2025',
		size: 'md',
		summary: 'University group project — a maintenance-management system on a relational DBMS.',
		description:
			'A COMP2411 group project at PolyU: a Computerized Maintenance Management System built on a relational database, covering schema design, normalization, SQL, and an application layer for managing work orders and assets.',
		highlights: [
			'Relational schema design and normalization',
			'SQL query layer for work orders and assets',
			'Team delivery for COMP2411 (Database Systems)',
		],
		stack: ['SQL', 'DBMS', 'Schema Design'],
		repo: 'https://github.com/Keegerrard/COMP2411_DBMS_CMMS_GroupProject',
	},
];
---

<Layout
	title="Keegan Gerrard Jahja | Finance × Tech"
	description="CS student at PolyU headed for investment banking — building AI and web systems along the way."
>
	<!-- ============================ HERO ============================ -->
	<section id="home" data-reveal class="reveal flex scroll-mt-16 flex-col items-center pt-16 pb-8 text-center sm:pt-24">
		<Image
			class="h-24 w-24 rounded-full object-cover object-top ring-1 ring-hairline"
			src={profilePhoto}
			alt="Portrait of Keegan Gerrard Jahja"
			width={192}
			loading="eager"
			decoding="async"
			fetchpriority="high"
		/>
		<p class="mt-6 text-sm font-medium text-ink-muted">
			Keegan Gerrard Jahja · Computer Science @ PolyU
		</p>
		<h1 class="mt-3 max-w-3xl text-5xl font-semibold tracking-[-0.03em] text-ink sm:text-7xl">
			Thinks finance.<br />Ships software.
		</h1>
		<p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-muted">
			CS student in Hong Kong headed for investment banking — building AI and web systems along
			the way, so the analysis comes with execution.
		</p>

		<div class="mt-8 flex items-center gap-6">
			<a
				href="#work"
				class="cursor-pointer rounded-full bg-accent px-5 py-2.5 text-[0.95rem] font-medium text-white transition-colors duration-200 hover:bg-accent-hover"
			>
				See the work
			</a>
			<a
				href={CV_PATH}
				download
				class="cursor-pointer text-[0.95rem] font-medium text-accent hover:underline"
			>
				Download CV <span aria-hidden="true">↓</span>
			</a>
		</div>

		<div class="mt-16 grid w-full max-w-3xl grid-cols-1 divide-y divide-hairline border-y border-hairline sm:grid-cols-3 sm:divide-x sm:divide-y-0">
			{stats.map((s) => (
				<div class="px-6 py-5">
					<p class="text-3xl font-semibold tracking-tight text-ink">{s.value}</p>
					<p class="mt-1 text-sm leading-snug text-ink-muted">{s.label}</p>
				</div>
			))}
		</div>
	</section>

	<!-- ====================== SKILLS TICKER ======================== -->
	<div class="marquee-mask mt-10 overflow-hidden" aria-hidden="true">
		<div class="marquee-track">
			{[0, 1].map(() => (
				<ul class="flex shrink-0 items-center gap-2.5 pr-2.5">
					{ticker.map((t) => (
						<li class="whitespace-nowrap rounded-full bg-panel px-4 py-2 text-sm text-ink-muted">
							{t}
						</li>
					))}
				</ul>
			))}
		</div>
	</div>

	<!-- ============================ ABOUT ========================== -->
	<section id="about" data-reveal class="reveal cv-auto scroll-mt-16 pt-24">
		<div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr]">
			<div>
				<h2 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
					Finance first. <span class="text-ink-faint">Engineering close behind.</span>
				</h2>
				<div class="mt-6 max-w-xl space-y-4 text-[1.05rem] leading-relaxed text-ink-muted">
					<p>
						My first seat in finance was at Trimegah Securities in Jakarta — client portfolios,
						risk profiles, equities and mutual funds. That's the work I'm going back to, at
						investment-banking scale.
					</p>
					<p>
						Everything since — AI workflows for pharmacies, web systems for real clients — is
						execution practice: precision, delivery, and translating between technical and
						non-technical people. The code is leverage, not the destination.
					</p>
				</div>
			</div>

			<div class="rounded-3xl bg-panel p-7">
				<p class="text-sm font-semibold text-ink">Right now</p>
				<ul class="mt-4 divide-y divide-hairline">
					{now.map((item) => (
						<li class="flex items-baseline justify-between gap-6 py-3">
							<span class="shrink-0 text-sm text-ink-faint">{item.label}</span>
							<span class="text-right text-sm font-medium text-ink">{item.value}</span>
						</li>
					))}
				</ul>
			</div>
		</div>
	</section>

	<!-- ======================== SELECTED WORK ====================== -->
	<section id="work" data-reveal class="reveal cv-auto scroll-mt-16 pt-24">
		<div class="flex flex-wrap items-end justify-between gap-4">
			<h2 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl">
				Work that shipped.
			</h2>
			<a
				href="https://github.com/Keegerrard"
				target="_blank"
				rel="noopener noreferrer"
				class="cursor-pointer text-sm font-medium text-accent hover:underline"
			>
				All repositories on GitHub <span aria-hidden="true">↗</span>
			</a>
		</div>
		<p class="mt-2 max-w-xl text-ink-muted">
			Tap any project to preview it — public code is linked directly.
		</p>

		<div class="mt-8">
			<ProjectGallery client:visible projects={projects} />
		</div>
	</section>

	<!-- ========================= JOURNEY =========================== -->
	<section id="journey" data-reveal class="reveal cv-auto scroll-mt-16 pt-24">
		<div class="flex flex-wrap items-end justify-between gap-4">
			<div>
				<h2 class="text-3xl font-semibold tracking-tight text-ink sm:text-4xl">The journey.</h2>
				<p class="mt-2 max-w-xl text-ink-muted">
					Two years, two cities — from a trading floor in Jakarta to production code in Hong Kong.
				</p>
			</div>
			<p class="hidden text-xs text-ink-faint sm:block" aria-hidden="true">Scroll →</p>
		</div>

		<div class="no-scrollbar -mx-5 mt-8 flex snap-x snap-mandatory gap-4 overflow-x-auto px-5 pb-2">
			{journey.map((stop) => (
				<article class="lift lift-shadow flex w-[300px] shrink-0 snap-start flex-col rounded-3xl border border-hairline bg-white p-6 shadow-[var(--shadow-rest)]">
					<div class="flex items-center justify-between text-xs text-ink-faint">
						<span class="font-medium">{stop.period}</span>
						<span>{stop.place}</span>
					</div>
					<h3 class="mt-5 text-xl font-semibold tracking-tight text-ink">{stop.headline}</h3>
					<p class="mt-2 flex-1 text-sm leading-relaxed text-ink-muted">{stop.detail}</p>
					<p class="mt-5 text-xs font-semibold text-ink-muted">{stop.org}</p>
				</article>
			))}

			<a
				href="#contact"
				class="lift lift-shadow flex w-[300px] shrink-0 cursor-pointer snap-start flex-col justify-between rounded-3xl bg-ink p-6 text-white"
			>
				<span class="text-xs font-medium text-white/60">Next stop</span>
				<div>
					<h3 class="text-xl font-semibold tracking-tight">Your team?</h3>
					<p class="mt-2 text-sm leading-relaxed text-white/70">
						Open to internship and graduate roles in IB and financial services.
					</p>
					<p class="mt-5 text-sm font-medium">Get in touch <span aria-hidden="true">›</span></p>
				</div>
			</a>
		</div>

		<p class="mt-6 text-sm text-ink-muted">
			Want the formal version?
			<a href={CV_PATH} download class="cursor-pointer font-medium text-accent hover:underline">
				Download the CV <span aria-hidden="true">↓</span>
			</a>
		</p>
	</section>

	<!-- ========================== CONTACT ========================== -->
	<section id="contact" data-reveal class="reveal cv-auto flex scroll-mt-16 flex-col items-center pt-28 text-center">
		<h2 class="text-4xl font-semibold tracking-[-0.03em] text-ink sm:text-5xl">Let's talk.</h2>
		<p class="mt-4 max-w-lg text-lg leading-relaxed text-ink-muted">
			Hiring for internships or graduate roles in investment banking or financial services? The
			inbox is open.
		</p>
		<div class="mt-8 flex flex-wrap items-center justify-center gap-4">
			<a
				href="mailto:keegan.jahja@connect.polyu.hk"
				class="cursor-pointer rounded-full bg-accent px-6 py-3 font-medium text-white transition-colors duration-200 hover:bg-accent-hover"
			>
				Email me
			</a>
			<a
				href={CV_PATH}
				download
				class="cursor-pointer rounded-full border border-hairline bg-white px-6 py-3 font-medium text-ink transition-colors duration-200 hover:bg-panel"
			>
				Download CV
			</a>
		</div>
		<div class="mt-6 flex flex-wrap items-center justify-center gap-6">
			<a
				href="https://github.com/Keegerrard"
				target="_blank"
				rel="noopener noreferrer"
				class="cursor-pointer text-[0.95rem] font-medium text-accent hover:underline"
			>
				GitHub <span aria-hidden="true">↗</span>
			</a>
			<a href="tel:+85254619905" class="cursor-pointer text-[0.95rem] font-medium text-accent hover:underline">
				+852 5461 9905
			</a>
		</div>
	</section>
</Layout>
